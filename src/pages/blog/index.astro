---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import RockCard from "../../components/RockCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import {
  BLOG_CATEGORIES,
  createBlogIdMap,
  formatBlogDate,
  getBlogCategoryLabel,
  getBlogPostPath,
  sortBlogPosts,
} from '../../lib/blog';

const posts = await getCollection('blog');
const featuredPosts = posts.filter((post) => post.data.featured);
const sortedPosts = sortBlogPosts(posts);
const postIdMap = createBlogIdMap(posts);

const toNumericId = (value: string) => (value.match(/\d+/)?.[0] ?? "0").padStart(4, "0");
---

<Layout title="BLOG | BubbleCrisp">
  <section class="page">
    <SectionHeader en="BLOG" cn="档案文本" count={posts.length} />
    <p class="subtitle">记录关于 AI、创造、商业与意识的探索样本。</p>

    <div class="category-nav" data-category-nav>
      {BLOG_CATEGORIES.map((category) => (
        <a
          href={category.slug === 'all' ? '/blog' : `/blog?category=${category.slug}`}
          class:list={['category-item', category.slug === 'all' && 'active']}
          data-category-trigger={category.slug}
        >
          {category.label}
        </a>
      ))}
    </div>

    <div class="posts-region" data-posts-region>
      {featuredPosts.length > 0 && (
        <div class="featured-section" data-post-section="featured">
          <p class="section-label">Featured</p>
          <p class="section-title">精选档案</p>
          <div class="posts-grid">
            {featuredPosts.map((post) => (
              <RockCard
                href={`/blog/${getBlogPostPath(post)}`}
                id={toNumericId(postIdMap.get(getBlogPostPath(post)) ?? "0000")}
                titleCn={post.data.title}
                titleEn={getBlogCategoryLabel(post.data.category)}
                date={formatBlogDate(post.data.pubDate)}
                data-category={post.data.category}
                data-post-card
              />
            ))}
          </div>
        </div>
      )}

      <div class="all-section" data-post-section="archive">
        <p class="section-label">Archive</p>
        <p class="section-title">档案库</p>
        <div class="posts-grid">
          {sortedPosts.map((post) => (
            <RockCard
              href={`/blog/${getBlogPostPath(post)}`}
              id={toNumericId(postIdMap.get(getBlogPostPath(post)) ?? "0000")}
              titleCn={post.data.title}
              titleEn={getBlogCategoryLabel(post.data.category)}
              date={formatBlogDate(post.data.pubDate)}
              data-category={post.data.category}
              data-post-card
            />
          ))}
        </div>
      </div>
    </div>

    <p class="empty-state" data-empty-state hidden>该分类下暂时还没有可阅读的档案。</p>
  </section>
</Layout>

<script is:inline define:vars={{ validCategories: BLOG_CATEGORIES.map((item) => item.slug) }}>
  const categoryNav = document.querySelector('[data-category-nav]');
  const postsRegion = document.querySelector('[data-posts-region]');
  const emptyState = document.querySelector('[data-empty-state]');

  if (categoryNav && postsRegion && emptyState) {
    const triggers = Array.from(categoryNav.querySelectorAll('[data-category-trigger]'));
    const cards = Array.from(document.querySelectorAll('[data-post-card]'));
    const sections = Array.from(document.querySelectorAll('[data-post-section]'));
    const validCategorySet = new Set(validCategories);

    const getCategoryFromUrl = () => {
      const currentUrl = new URL(window.location.href);
      const category = currentUrl.searchParams.get('category') ?? 'all';
      return validCategorySet.has(category) ? category : 'all';
    };

    const syncUrl = (category, replace = false) => {
      const currentUrl = new URL(window.location.href);
      if (category === 'all') {
        currentUrl.searchParams.delete('category');
      } else {
        currentUrl.searchParams.set('category', category);
      }

      const nextUrl = `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`;
      if (replace) {
        window.history.replaceState({}, '', nextUrl);
      } else {
        window.history.pushState({}, '', nextUrl);
      }
    };

    const updateActiveState = (category) => {
      triggers.forEach((trigger) => {
        const isActive = trigger.getAttribute('data-category-trigger') === category;
        trigger.classList.toggle('active', isActive);
        trigger.setAttribute('aria-current', isActive ? 'page' : 'false');
      });
    };

    const applyFilter = (category) => {
      cards.forEach((card) => {
        const matches = category === 'all' || card.getAttribute('data-category') === category;
        card.hidden = !matches;
      });

      sections.forEach((section) => {
        const visibleCards = section.querySelectorAll('[data-post-card]:not([hidden])');
        section.hidden = visibleCards.length === 0;
      });

      const hasVisibleCards = cards.some((card) => !card.hidden);
      emptyState.hidden = hasVisibleCards;
      updateActiveState(category);
    };

    const transitionTo = (category) => {
      postsRegion.classList.add('is-transitioning');
      window.setTimeout(() => {
        applyFilter(category);
        postsRegion.classList.remove('is-transitioning');
      }, 170);
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        const nextCategory = trigger.getAttribute('data-category-trigger') ?? 'all';
        if (nextCategory === getCategoryFromUrl()) {
          return;
        }

        syncUrl(nextCategory);
        transitionTo(nextCategory);
      });
    });

    window.addEventListener('popstate', () => {
      applyFilter(getCategoryFromUrl());
    });

    const initialCategory = getCategoryFromUrl();
    applyFilter(initialCategory);
    syncUrl(initialCategory, true);
  }
</script>

<style>
.page {
  padding: var(--space-16) 0;
}

.subtitle {
  font-size: var(--text-lg);
  color: var(--paper-rust);
  line-height: 1.75;
  margin: 0 0 var(--space-8) 0;
}

.category-nav {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-bottom: var(--space-12);
  padding-bottom: var(--space-6);
  border-bottom: var(--border-thin);
}

.category-item {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--rock-granite);
  cursor: pointer;
  padding: var(--space-2) 0;
  transition:
    color var(--duration-base) var(--ease-out),
    border-color var(--duration-base) var(--ease-out);
  border-bottom: 1px solid transparent;
}

.category-item:hover {
  color: var(--paper-bone);
}

.category-item.active {
  color: var(--paper-bone);
  border-bottom: 1px solid var(--mineral-copper);
}

.posts-region {
  opacity: 1;
  transition: opacity 180ms var(--ease-out);
}

.posts-region.is-transitioning {
  opacity: 0.32;
}

.featured-section,
.all-section {
  margin-bottom: var(--space-16);
}

.section-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin: 0 0 var(--space-2) 0;
}

.section-title {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  font-weight: 400;
  margin: 0 0 var(--space-6) 0;
  color: var(--paper-bone);
}

.posts-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.empty-state {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--rock-granite);
  margin: 0;
}
</style>
