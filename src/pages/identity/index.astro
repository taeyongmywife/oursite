---
import Layout from "../../layouts/Layout.astro";
import ChoicePanel from "../../components/ChoicePanel.astro";
import MineralFigure from "../../components/MineralFigure.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import pyrite from "../../assets/mineral/02-pyrite-cubes.png";
---

<Layout title="IDENTITY | BubbleCrisp" description="About the creator behind BubbleCrisp.">
  <section class="page">
    <SectionHeader en="IDENTITY" cn="矿主自述" />

    <section class="identity-bio">
      <div class="bio-figure">
        <MineralFigure src={pyrite} alt="Pyrite cubes specimen" width={80} height={80} />
      </div>
      <dl class="bio-meta">
        <dt>NAME</dt>
        <dd>[your name]</dd>
        <dt>ROLE</dt>
        <dd>Founder, BubbleCrisp</dd>
        <dt>LOCATION</dt>
        <dd>[your location]</dd>
      </dl>
    </section>

    <section class="block">
      <h3 class="block-title">BIOGRAPHY</h3>
      <div class="block-body">
        <p>这里是一份持续更新的个人档案。写作、实验、以及对系统的长期维护。</p>
        <p>This is a cabinet still being built. I collect questions, form them into systems, and file the residue.</p>
      </div>
    </section>

    <section class="block">
      <h3 class="block-title">ABOUT THIS CABINET</h3>
      <div class="block-body">
        <p>它不是作品集，也不是即时新闻。它更像一张缓慢生长的地层剖面。</p>
        <p>Not a portfolio. Not a feed. A long-term container for crystallizing ideas.</p>
      </div>
    </section>

    <section class="block">
      <h3 class="block-title">CONTACT</h3>
      <div class="contact-links">
        <a href="mailto:mail@example.com">✉ email</a>
        <a href="https://github.com/" target="_blank" rel="noreferrer">⌘ github</a>
        <a href="/rss.xml">◇ rss</a>
      </div>
    </section>

    <section class="block">
      <h3 class="block-title">COLOPHON</h3>
      <div class="block-body">
        <p>Built with Astro · Deployed on Vercel · Typeset with EB Garamond / JetBrains Mono</p>
      </div>
    </section>

    <ChoicePanel
      prompt="离开档案柜 / Close this cabinet"
      options={[{ label: "回到首页", href: "/" }]}
    />
  </section>
</Layout>

<style>
.page {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.identity-bio {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: var(--space-6);
  padding: var(--space-6);
  border: var(--border-thin);
  background: var(--bg-shelf);
  margin-bottom: var(--space-12);
}

.bio-figure {
  width: 80px;
}

.bio-meta {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: var(--space-2) var(--space-6);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rock-granite);
  margin: 0;
}

.bio-meta dt {
  margin: 0;
}

.bio-meta dd {
  margin: 0;
  letter-spacing: 0;
  text-transform: none;
  color: var(--paper-bone);
}

.block {
  padding-bottom: var(--space-12);
  border-bottom: var(--border-thin);
  margin-bottom: var(--space-12);
}

.block:last-of-type {
  border-bottom: none;
  padding-bottom: 0;
  margin-bottom: 0;
}

.block-title {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--paper-bone);
  margin: 0 0 var(--space-4) 0;
}

.block-body {
  color: var(--paper-bone);
}

.block-body p {
  margin: 0 0 var(--space-6) 0;
}

.block-body p:last-child {
  margin-bottom: 0;
}

.contact-links {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-6);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  letter-spacing: 0.05em;
}

.contact-links a {
  color: var(--paper-bone);
  text-decoration: none;
}

.contact-links a:hover {
  color: var(--mineral-copper);
  text-decoration: underline;
}

@media (max-width: 640px) {
  .identity-bio {
    grid-template-columns: 1fr;
  }

  .bio-figure {
    width: 80px;
  }
}
</style>
