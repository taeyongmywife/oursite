---
import Layout from "../layouts/Layout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import RockCard from "../components/RockCard.astro";

const payloadUrl = import.meta.env.PUBLIC_PAYLOAD_URL;
let posts = [];

try {
  const res = await fetch(`${payloadUrl}/api/posts`);
  if (res.ok) {
    const data = await res.json();
    posts = data.docs ?? [];
  } else {
    console.warn(`[home] Posts fetch returned ${res.status}`);
  }
} catch (err) {
  console.warn(`[home] Failed to fetch posts: ${err}`);
}

const fragments = await getCollection("fragments");
const latestFragments = [...fragments].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const currentId = String(fragments.length).padStart(4, "0");
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="hero">
    <div class="hero-top">
      <div class="hero-welcome">WELCOME, STRANGER.</div>
      <div class="hero-id">[SPECIMEN #{currentId}]</div>
    </div>

    <h1 class="hero-title-cn">你正在进入一个未命名空间</h1>
    <div class="hero-title-en">Entering an Unnamed Space</div>

    <div class="hero-line"></div>

    <div class="hero-desc">
      <p>这里存放着持续结晶的想法、观察、产物。</p>
      <p>Each idea here is a specimen in a cabinet still being built.</p>
    </div>

    <a class="hero-cta" href="/fragments">[▸ ENTER THE CABINET]</a>
    <a href="/between" class="between-easter-egg" aria-label="between">between</a>
  </section>

  <section class="recent">
    <div class="recent-title">RECENT CRYSTALLIZATION</div>
      <div class="recent-list">
       {posts.map((post) => (
       <div>
        <h3>{post.title}</h3>
        <p>{post.slug}</p>
      </div>
       ))}
      </div>
  </section>
</Layout>

<style>
.hero {
  position: relative;
  padding: var(--space-16) 0 var(--space-12) 0;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: var(--space-4);
}

.hero-welcome {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.hero-id {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--mineral-copper);
  letter-spacing: 0.1em;
}

.hero-title-cn {
  font-family: var(--font-serif);
  font-size: var(--text-4xl);
  font-weight: 600;
  line-height: 1.15;
  margin: var(--space-6) 0 var(--space-2) 0;
}

.hero-title-en {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--paper-rust);
  letter-spacing: 0.1em;
}

.hero-line {
  height: 1px;
  background: var(--rock-basalt);
  margin: var(--space-6) 0;
}

.hero-desc {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  color: var(--paper-bone);
}

.hero-desc p {
  margin: 0;
}

.hero-cta {
  display: inline-block;
  margin-top: var(--space-8);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  letter-spacing: 0.1em;
  text-decoration: none;
  color: var(--paper-bone);
}

.hero-cta:hover {
  color: var(--mineral-copper);
}

.between-easter-egg {
  position: absolute;
  right: var(--space-8);
  bottom: var(--space-8);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-basalt);
  text-decoration: none;
  letter-spacing: 0.2em;
  transition:
    color 800ms var(--ease-out),
    letter-spacing 800ms var(--ease-out);
}

.between-easter-egg:hover {
  color: var(--mineral-copper);
  letter-spacing: 0.3em;
}

.recent {
  padding: var(--space-12) 0 var(--space-16) 0;
}

.recent-title {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--paper-bone);
  margin-bottom: var(--space-6);
}

.recent-list {
  display: flex;
  flex-direction: column;
}

@media (max-width: 768px) {
  .hero {
    padding: var(--space-12) 0;
  }

  .hero-top {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .hero-title-cn {
    font-size: clamp(2rem, 9vw, 2.5rem);
    margin-top: var(--space-4);
  }

  .hero-title-en {
    letter-spacing: 0.06em;
    line-height: 1.5;
  }

  .hero-cta {
    margin-top: var(--space-6);
    font-size: var(--text-xs);
  }

  .between-easter-egg {
    right: 0;
    bottom: 0;
  }

  .recent {
    padding: var(--space-8) 0 var(--space-12) 0;
  }
}
</style>
