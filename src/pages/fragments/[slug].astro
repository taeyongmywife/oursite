---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from 'astro:content';
import ChoicePanel from "../../components/ChoicePanel.astro";
import MineralFigure from "../../components/MineralFigure.astro";
import SpecimenLabel from "../../components/SpecimenLabel.astro";
import quartz from "../../assets/mineral/01-quartz-cluster-dark.jpg";

export async function getStaticPaths() {
  const fragments = await getCollection('fragments');
  return fragments.map((fragment) => ({
    params: { slug: fragment.id.replace(/\.(md|mdx)$/, "") },
  }));
}

const fragments = await getCollection('fragments');
const slug = Astro.params.slug;
const fragment = fragments.find((entry) => entry.id.replace(/\.(md|mdx)$/, "") === slug);

if (!fragment) {
  throw new Error(`Fragment not found for slug: ${slug}`);
}

const { Content } = await render(fragment);
const collected = fragment.data.pubDate.toISOString().split("T")[0];
const status =
  fragment.data.status?.toLowerCase?.().includes("archive") ? "archived" : "crystallizing";
const sorted = [...fragments].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const specimenId = String(sorted.findIndex((entry) => entry.id === fragment.id) + 1).padStart(
  4,
  "0",
);
const heroFigure = fragment.data.heroImage ?? quartz;
const heroAlt = fragment.data.heroImage
  ? `${fragment.data.title} figure`
  : "Dark quartz cluster specimen";
---

<Layout title={`${fragment.data.title} | FRAGMENTS`} description={fragment.data.title}>
  <article class="fragment-detail">
    <SpecimenLabel
      id={specimenId}
      titleCn={fragment.data.title}
      titleEn={fragment.data.subject}
      collected={collected}
      location="digital sediment"
      composition={`${fragment.data.type} / ${fragment.data.subject}`}
      status={status}
      variant="full"
    />

    <div class="hero-figure">
      <MineralFigure src={heroFigure} alt={heroAlt} caption="Specimen figure" />
    </div>

    <div class="fragment-content">
      <Content />
      {fragment.id === "groove.md" && (
        <p class="between-whisper">
          那之后我没有再说话。<a href="/between" class="inline-between">between</a>
        </p>
      )}
    </div>

    <ChoicePanel
      prompt="你看向她，眼神里带着"
      options={[
        { label: "回到陈列", href: "/fragments" },
        { label: "继续探索", href: "/experiments" },
      ]}
    />

    <a href="/fragments" class="back-link">[ BACK TO FRAGMENTS ]</a>
  </article>
</Layout>

<style>
.fragment-detail {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.hero-figure {
  margin-top: var(--space-8);
}

.fragment-content {
  font-size: var(--text-base);
  line-height: 1.75;
  color: var(--paper-bone);
  margin-top: var(--space-12);
}

.fragment-content :global(p) {
  margin: 0 0 var(--space-6) 0;
}

.fragment-content :global(h2) {
  font-size: var(--text-2xl);
  font-weight: 400;
  margin: var(--space-12) 0 var(--space-4) 0;
}

.fragment-content :global(ul) {
  margin: 0 0 var(--space-6) 0;
  padding-left: var(--space-6);
}

.between-whisper {
  margin: 0 0 var(--space-6) 0;
}

.inline-between {
  margin-left: 0.25em;
  color: var(--paper-bone);
  text-decoration: none;
  border-bottom: 1px dashed var(--rock-granite);
  transition: border-color var(--duration-base) var(--ease-out);
}

.inline-between:hover {
  border-bottom-color: var(--mineral-copper);
}

.back-link {
  display: inline-block;
  margin-top: var(--space-12);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--paper-bone);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.back-link:hover {
  opacity: 0.7;
}
</style>
