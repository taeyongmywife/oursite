---
import Layout from "../../layouts/Layout.astro";
import ChoicePanel from "../../components/ChoicePanel.astro";
import MineralFigure from "../../components/MineralFigure.astro";
import SpecimenLabel from "../../components/SpecimenLabel.astro";
import RichText from "../../components/RichText.astro";
import { getPosts, getPostBySlug } from "../../lib/payload";
import quartz from "../../assets/mineral/01-quartz-cluster-dark.jpg";

export async function getStaticPaths() {
  const fragments = await getPosts("fragment");
  return fragments.map((fragment) => ({
    params: { slug: fragment.slug },
  }));
}

const fragment = await getPostBySlug(Astro.params.slug);

if (!fragment) {
  throw new Error(`Fragment not found for slug: ${Astro.params.slug}`);
}

const collected = fragment.createdAt?.split("T")[0] ?? "";
const status =
  fragment.status?.toLowerCase?.().includes("archiv") ? "archived" : "crystallizing";
const specimens = await getPosts("fragment");
const specimenId = String(
  specimens.findIndex((e) => e.slug === fragment.slug) + 1
).padStart(4, "0");
---

<Layout title={`${fragment.title} | FRAGMENTS`} description={fragment.title}>
  <article class="fragment-detail">
    <SpecimenLabel
      id={specimenId}
      titleCn={fragment.title}
      titleEn={fragment.title}
      collected={collected}
      location="digital sediment"
      status={status}
      variant="full"
    />

    <div class="hero-figure">
      <MineralFigure src={quartz} alt="Dark quartz cluster specimen" />
    </div>

    <div class="fragment-content">
      <RichText content={fragment.content} />
      {fragment.slug === "groove" && (
        <p class="between-whisper">
          那之后我没有再说话。<a href="/between" class="inline-between">between</a>
        </p>
      )}
    </div>

    <ChoicePanel
      prompt="你看向她，眼神里带着"
      options={[
        { label: "回到陈列", href: "/fragments" },
        { label: "继续探索", href: "/experiments" },
      ]}
    />

    <a href="/fragments" class="back-link">[ BACK TO FRAGMENTS ]</a>
  </article>
</Layout>

<style>
.fragment-detail {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.hero-figure {
  margin-top: var(--space-8);
}

.fragment-content {
  font-size: var(--text-base);
  line-height: 1.75;
  color: var(--paper-bone);
  margin-top: var(--space-12);
}

.fragment-content :global(p) {
  margin: 0 0 var(--space-6) 0;
}

.fragment-content :global(h2) {
  font-size: var(--text-2xl);
  font-weight: 400;
  margin: var(--space-12) 0 var(--space-4) 0;
}

.fragment-content :global(ul) {
  margin: 0 0 var(--space-6) 0;
  padding-left: var(--space-6);
}

.between-whisper {
  margin: 0 0 var(--space-6) 0;
}

.inline-between {
  margin-left: 0.25em;
  color: var(--paper-bone);
  text-decoration: none;
  border-bottom: 1px dashed var(--rock-granite);
  transition: border-color var(--duration-base) var(--ease-out);
}

.inline-between:hover {
  border-bottom-color: var(--mineral-copper);
}

.back-link {
  display: inline-block;
  margin-top: var(--space-12);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--paper-bone);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.back-link:hover {
  opacity: 0.7;
}
</style>
