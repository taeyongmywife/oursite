---
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TagBox from "../../components/TagBox.astro";

import { getPosts } from "../../lib/payload";

const fragments = await getPosts("fragment");

// Group fragments by tag
const grouped: Record<string, { tag: { id: number; title: string; slug: string }; posts: Array<{ title: string; slug: string; createdAt: string }> }> = {};

for (const fragment of fragments) {
  const postTags = Array.isArray(fragment.tags) ? fragment.tags : [];

  if (postTags.length === 0) {
    const key = "__untagged__";
    if (!grouped[key]) {
      grouped[key] = {
        tag: { id: -1, title: "Untagged", slug: "" },
        posts: [],
      };
    }
    grouped[key].posts.push({
      title: fragment.title,
      slug: fragment.slug,
      createdAt: fragment.createdAt,
    });
    continue;
  }

  for (const tag of postTags) {
    const tagId = typeof tag === "number" ? tag : tag.id;
    const tagTitle = typeof tag === "number" ? `Tag #${tag}` : tag.title;
    const tagSlug = typeof tag === "number" ? "" : tag.slug;

    const key = String(tagId);
    if (!grouped[key]) {
      grouped[key] = {
        tag: { id: tagId, title: tagTitle, slug: tagSlug },
        posts: [],
      };
    }
    grouped[key].posts.push({
      title: fragment.title,
      slug: fragment.slug,
      createdAt: fragment.createdAt,
    });
  }
}

const sortedGroups = Object.values(grouped).sort((a, b) => {
  const countDiff = b.posts.length - a.posts.length;
  if (countDiff !== 0) return countDiff;
  return a.tag.title.localeCompare(b.tag.title);
});
---

<Layout
  title="FRAGMENTS | BubbleCrisp"
  description="Each entry is a specimen. Crystallized from fleeting thoughts, observations, and rough notes."
>
  <section class="page">
    <SectionHeader en="FRAGMENTS" cn="碎片档案" count={fragments.length} />
    <p class="section-intro">
      Each entry is a specimen. Crystallized from fleeting thoughts, observations, and rough notes.
    </p>

    {sortedGroups.length > 0 ? (
      <div class="tag-group">
        {sortedGroups.map((group) => (
          <TagBox tag={group.tag} posts={group.posts} basePath="/fragments" />
        ))}
      </div>
    ) : (
      <div class="empty">暂无碎片档案。</div>
    )}
  </section>
</Layout>

<style>
.page {
  padding: var(--space-16) 0;
}

.section-intro {
  margin: 0 0 var(--space-8) 0;
  color: var(--paper-rust);
}

.tag-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.empty {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--rock-granite);
  text-align: center;
  padding: var(--space-16) 0;
}
</style>
