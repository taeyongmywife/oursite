---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';
import RockCard from "../../components/RockCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";

const fragments = await getCollection("fragments");
const sorted = [...fragments].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout
  title="FRAGMENTS | BubbleCrisp"
  description="Each entry is a specimen. Crystallized from fleeting thoughts, observations, and rough notes."
>
  <section class="page">
    <SectionHeader en="FRAGMENTS" cn="碎片档案" count={fragments.length} />
    <p class="section-intro">
      Each entry is a specimen. Crystallized from fleeting thoughts, observations, and rough notes.
    </p>

    <div class="list">
      {sorted.map((fragment, i) => (
        <RockCard
          id={String(fragments.length - i)}
          titleCn={fragment.data.title}
          titleEn={fragment.data.subject}
          date={fragment.data.pubDate.toISOString().split("T")[0]}
          href={`/fragments/${fragment.id.replace(/\.(md|mdx)$/, "")}`}
          variant="card"
        />
      ))}
    </div>
  </section>
</Layout>

<style>
.page {
  padding: var(--space-16) 0;
}

.section-intro {
  margin: 0 0 var(--space-8) 0;
  color: var(--paper-rust);
}

.list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}
</style>
