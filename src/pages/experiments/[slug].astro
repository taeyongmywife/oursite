---
import Layout from "../../layouts/Layout.astro";
import ChoicePanel from "../../components/ChoicePanel.astro";
import SpecimenLabel from "../../components/SpecimenLabel.astro";
import RichText from "../../components/RichText.astro";
import { getPosts, getPostBySlug } from "../../lib/payload";

export async function getStaticPaths() {
  const experiments = await getPosts("experiment");
  return experiments.map((exp) => ({
    params: { slug: exp.slug },
  }));
}

const experiment = await getPostBySlug(Astro.params.slug);

if (!experiment) {
  throw new Error(`Experiment not found for slug: ${Astro.params.slug}`);
}

const collected = experiment.createdAt?.split("T")[0] ?? "";
const specimens = await getPosts("experiment");
const specimenId = String(
  specimens.findIndex((e) => e.slug === experiment.slug) + 1
).padStart(4, "0");

const statusLabel =
  experiment.status === "published" || experiment.status === "Completed"
    ? "archived"
    : "crystallizing";
---

<Layout title={`${experiment.title} | EXPERIMENTS`} description={experiment.title}>
  <article class="experiment-detail">
    <SpecimenLabel
      id={specimenId}
      titleCn={experiment.title}
      titleEn={experiment.excerpt ?? experiment.title}
      collected={collected}
      location="digital sediment"
      status={statusLabel}
      variant="full"
    />

    {experiment.excerpt && (
      <div class="meta-section">
        <div class="meta-section-title">OBJECTIVE</div>
        <p class="meta-section-content">{experiment.excerpt}</p>
      </div>
    )}

    <div class="experiment-content">
      <RichText content={experiment.content} />
    </div>

    <ChoicePanel
      prompt="Select your next move."
      options={[
        { label: "Back to experiments", href: "/experiments" },
        { label: "Enter fragments", href: "/fragments" },
      ]}
    />

    <a href="/experiments" class="back-link">[ BACK TO EXPERIMENTS ]</a>
  </article>
</Layout>

<style>
.experiment-detail {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.meta-section {
  margin-bottom: var(--space-8);
  padding: var(--space-6);
  border: var(--border-thin);
  background: var(--bg-shelf);
}

.meta-section-title {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rock-granite);
  margin-bottom: var(--space-3);
}

.meta-section-content {
  font-size: var(--text-base);
  color: var(--paper-bone);
  margin: 0;
  line-height: 1.75;
}

.experiment-content {
  font-size: var(--text-base);
  line-height: 1.75;
  color: var(--paper-bone);
}

.experiment-content :global(p) {
  margin: 0 0 var(--space-4) 0;
}

.experiment-content :global(h2) {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  margin: var(--space-8) 0 var(--space-4) 0;
}

.experiment-content :global(ul) {
  margin: 0 0 var(--space-4) 0;
  padding-left: var(--space-6);
}

.back-link {
  display: inline-block;
  margin-top: var(--space-12);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--paper-bone);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.back-link:hover {
  opacity: 0.7;
}
</style>
