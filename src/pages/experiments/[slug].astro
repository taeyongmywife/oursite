---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from 'astro:content';
import ChoicePanel from "../../components/ChoicePanel.astro";
import SpecimenLabel from "../../components/SpecimenLabel.astro";

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((exp) => ({
    params: { slug: exp.id.replace(/\.(md|mdx)$/, "") },
  }));
}

const experiments = await getCollection('experiments');
const slug = Astro.params.slug;
const experiment = experiments.find((entry) => entry.id.replace(/\.(md|mdx)$/, "") === slug);

if (!experiment) {
  throw new Error(`Experiment not found for slug: ${slug}`);
}

const { Content } = await render(experiment);
const collected = experiment.data.pubDate.toISOString().split("T")[0];
const sorted = [...experiments].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const specimenId = String(sorted.findIndex((entry) => entry.id === experiment.id) + 1).padStart(
  4,
  "0",
);
---

<Layout title={`${experiment.data.title} | EXPERIMENTS`} description={experiment.data.title}>
  <article class="experiment-detail">
    <SpecimenLabel
      id={specimenId}
      titleCn={experiment.data.title}
      titleEn={experiment.data.lab}
      collected={collected}
      location="digital sediment"
      composition={`tools / ${experiment.data.tools.join(" / ")}`}
      status={experiment.data.status === "Completed" ? "archived" : "crystallizing"}
      variant="full"
    />

    <div class="meta-section">
      <div class="meta-section-title">OBJECTIVE</div>
      <p class="meta-section-content">{experiment.data.objective}</p>
    </div>

    <div class="meta-section">
      <div class="meta-section-title">TOOLS</div>
      <div class="tools-list">
        {experiment.data.tools.map((tool) => (
          <span class="tool-tag">{tool}</span>
        ))}
      </div>
    </div>

    <div class="experiment-content">
      <Content />
    </div>

    <ChoicePanel
      prompt="Select your next move."
      options={[
        { label: "Back to experiments", href: "/experiments" },
        { label: "Enter fragments", href: "/fragments" },
      ]}
    />

    <a href="/experiments" class="back-link">[ BACK TO EXPERIMENTS ]</a>
  </article>
</Layout>

<style>
.experiment-detail {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.meta-section {
  margin-bottom: var(--space-8);
  padding: var(--space-6);
  border: var(--border-thin);
  background: var(--bg-shelf);
}

.meta-section-title {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rock-granite);
  margin-bottom: var(--space-3);
}

.meta-section-content {
  font-size: var(--text-base);
  color: var(--paper-bone);
  margin: 0;
  line-height: 1.75;
}

.tools-list {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.tool-tag {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--paper-bone);
  border: var(--border-solid);
  padding: var(--space-1) var(--space-3);
  background: var(--bg-void);
}

.experiment-content {
  font-size: var(--text-base);
  line-height: 1.75;
  color: var(--paper-bone);
}

.experiment-content :global(p) {
  margin: 0 0 var(--space-4) 0;
}

.experiment-content :global(h2) {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  margin: var(--space-8) 0 var(--space-4) 0;
}

.experiment-content :global(ul) {
  margin: 0 0 var(--space-4) 0;
  padding-left: var(--space-6);
}

.back-link {
  display: inline-block;
  margin-top: var(--space-12);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--paper-bone);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.back-link:hover {
  opacity: 0.7;
}
</style>
