---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import SectionHeader from "../../components/SectionHeader.astro";

const experiments = await getCollection("experiments");
const sorted = [...experiments].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout title="EXPERIMENTS | BubbleCrisp" description="Experiment Lab - A record of ongoing projects.">
  <section class="page">
    <SectionHeader en="EXPERIMENTS · IN PROGRESS" cn="实验记录 · 在制品" count={experiments.length} />
    <p class="section-intro">
      Ongoing systems and small tests. The lab stays dim, but active.
    </p>
    <div class="section-note">▣ 此处陈列 {experiments.length} 件在制品标本</div>

    <div class="list">
      {sorted.map((exp, i) => (
        <a href={`/experiments/${exp.id.replace(/\.(md|mdx)$/, "")}`} class="exp-item">
          <div class="exp-head">
            <div class="exp-id">#{String(experiments.length - i).padStart(4, "0")}</div>
            <div class="exp-status">STATUS: CRYSTALLIZING</div>
          </div>
          <div class="exp-title">{exp.data.title}</div>
          <div class="exp-meta">{exp.data.lab} · {exp.data.pubDate.toISOString().split("T")[0]}</div>
          <div class="exp-desc">{exp.data.objective}</div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
.page {
  position: relative;
  padding: var(--space-16) 0;
}

.section-intro {
  position: relative;
  z-index: 1;
  margin: 0 0 var(--space-8) 0;
  color: var(--paper-rust);
}

.section-note {
  position: relative;
  z-index: 1;
  margin: 0 0 var(--space-6) 0;
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  letter-spacing: 0.05em;
  color: var(--rock-granite);
}

.list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.exp-item {
  display: block;
  padding: var(--space-6);
  border: var(--border-solid);
  background: rgba(10, 10, 12, 0.72);
  text-decoration: none;
  color: var(--paper-bone);
  transition: opacity var(--duration-base) var(--ease-out);
}

.exp-item:hover {
  opacity: 0.85;
}

.exp-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: var(--space-4);
  margin-bottom: var(--space-2);
}

.exp-id {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--mineral-copper);
}

.exp-status {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.exp-title {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
}

.exp-meta {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  margin-top: var(--space-1);
}

.exp-desc {
  margin-top: var(--space-3);
  color: var(--paper-rust);
}
</style>
