---
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import TagBox from "../../components/TagBox.astro";
import { getPosts } from "../../lib/payload";

const experiments = await getPosts("experiment");

// Group experiments by tag
const grouped: Record<string, { tag: { id: number; title: string; slug: string }; posts: Array<{ title: string; slug: string; createdAt: string }> }> = {};

for (const exp of experiments) {
  const postTags = Array.isArray(exp.tags) ? exp.tags : [];

  if (postTags.length === 0) {
    const key = "__untagged__";
    if (!grouped[key]) {
      grouped[key] = {
        tag: { id: -1, title: "Untagged", slug: "" },
        posts: [],
      };
    }
    grouped[key].posts.push({
      title: exp.title,
      slug: exp.slug,
      createdAt: exp.createdAt,
    });
    continue;
  }

  for (const tag of postTags) {
    const tagId = typeof tag === "number" ? tag : tag.id;
    const tagTitle = typeof tag === "number" ? `Tag #${tag}` : tag.title;
    const tagSlug = typeof tag === "number" ? "" : tag.slug;

    const key = String(tagId);
    if (!grouped[key]) {
      grouped[key] = {
        tag: { id: tagId, title: tagTitle, slug: tagSlug },
        posts: [],
      };
    }
    grouped[key].posts.push({
      title: exp.title,
      slug: exp.slug,
      createdAt: exp.createdAt,
    });
  }
}

const sortedGroups = Object.values(grouped).sort((a, b) => {
  const countDiff = b.posts.length - a.posts.length;
  if (countDiff !== 0) return countDiff;
  return a.tag.title.localeCompare(b.tag.title);
});
---

<Layout title="EXPERIMENTS · IN PROGRESS | BubbleCrisp" description="Experiment Lab - A record of ongoing projects.">
  <section class="page">
    <SectionHeader en="EXPERIMENTS · IN PROGRESS" cn="实验记录 · 在制品" count={experiments.length} />
    <p class="section-intro">
      Ongoing systems and small tests. The lab stays dim, but active.
    </p>

    {sortedGroups.length > 0 ? (
      <div class="tag-group">
        {sortedGroups.map((group) => (
          <TagBox tag={group.tag} posts={group.posts} basePath="/experiments" />
        ))}
      </div>
    ) : (
      <div class="empty">暂无实验记录。</div>
    )}
  </section>
</Layout>

<style>
.page {
  position: relative;
  padding: var(--space-16) 0;
}

.section-intro {
  position: relative;
  z-index: 1;
  margin: 0 0 var(--space-8) 0;
  color: var(--paper-rust);
}

.tag-group {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.empty {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--rock-granite);
  text-align: center;
  padding: var(--space-16) 0;
}
</style>
