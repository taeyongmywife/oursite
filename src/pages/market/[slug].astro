---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from 'astro:content';
import SpecimenLabel from "../../components/SpecimenLabel.astro";
import BuyButton from "../../components/BuyButton.astro";
import RelatedReferences from "../../components/RelatedReferences.astro";

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((p) => ({
    params: { slug: p.id.replace(/\.(md|mdx)$/, '') },
  }));
}

const products = await getCollection('products');
const slug = Astro.params.slug;
const product = products.find((entry) => entry.id.replace(/\.(md|mdx)$/, '') === slug);

if (!product) {
  throw new Error(`Product not found for slug: ${slug}`);
}

const { Content } = await render(product);
const collected = product.data.pubDate.toISOString().split("T")[0];
const sortedProducts = [...products].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const specimenId = String(sortedProducts.findIndex((entry) => entry.id === product.id) + 1).padStart(3, "0");
---

<Layout title={`${product.data.title} | MARKET`} description={product.data.subject}>
  <article class="product-detail">
    <SpecimenLabel
      id={specimenId}
      titleCn={product.data.title}
      titleEn={product.data.subject}
      collected={collected}
      location={`Market · ${product.data.category}`}
      composition="Product"
      status={product.data.status === "Available" ? "available" : "coming-soon"}
      variant="full"
    />

    {product.data.coverImage && (
      <div class="product-cover">
        <img src={product.data.coverImage.src} alt={product.data.title} />
      </div>
    )}

    <div class="product-info">
      {product.data.price && (
        <div class="product-price">{product.data.price}</div>
      )}
      <BuyButton
        purchaseChannel={product.data.purchaseChannel}
        externalUrl={product.data.externalUrl}
      />
    </div>

    {product.data.specs && (
      <div class="specs-section">
        <div class="specs-title">SPECIFICATIONS</div>
        <div class="specs-list">
          {Object.entries(product.data.specs).map(([key, value]) => (
            <div class="spec-item">
              <div class="spec-key">{key}</div>
              <div class="spec-value">{value}</div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="product-content">
      <Content />
    </div>

    <RelatedReferences
      relatedExperiments={product.data.relatedExperiments}
      relatedFragments={product.data.relatedFragments}
    />

    <a href="/market" class="back-link">[ BACK TO MARKET ]</a>
  </article>
</Layout>

<style>
.product-detail {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.product-cover {
  margin: var(--space-12) 0;
  width: 100%;
  aspect-ratio: 16/9;
  border: var(--border-solid);
  background: var(--bg-shelf);
  overflow: hidden;
}

.product-cover img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-8) 0;
  border-top: var(--border-thin);
  border-bottom: var(--border-thin);
}

.product-price {
  font-family: var(--font-serif);
  font-size: var(--text-2xl);
  color: var(--mineral-copper);
}

.specs-section {
  margin: var(--space-12) 0;
}

.specs-title {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--paper-bone);
  margin-bottom: var(--space-6);
}

.specs-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.spec-item {
  display: flex;
  justify-content: space-between;
  padding: var(--space-4) 0;
  border-bottom: 1px dashed var(--rock-granite);
}

.spec-key {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  color: var(--rock-granite);
  text-transform: uppercase;
}

.spec-value {
  font-family: var(--font-serif);
  font-size: var(--text-base);
  color: var(--paper-bone);
}

.product-content {
  font-size: var(--text-base);
  line-height: 1.75;
  color: var(--paper-bone);
  margin-top: var(--space-12);
}

.product-content :global(p) {
  margin: 0 0 var(--space-4) 0;
}

.product-content :global(h2) {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  margin: var(--space-8) 0 var(--space-4) 0;
}

.back-link {
  display: inline-block;
  margin-top: var(--space-12);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--paper-bone);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.back-link:hover {
  opacity: 0.7;
}
</style>
