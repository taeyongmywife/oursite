---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from 'astro:content';
import ChoicePanel from "../../components/ChoicePanel.astro";
import SpecimenLabel from "../../components/SpecimenLabel.astro";

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((c) => ({
    params: { slug: c.id.replace(/\.(md|mdx)$/, "") },
  }));
}

const cases = await getCollection('cases');
const slug = Astro.params.slug;
const caseData = cases.find((entry) => entry.id.replace(/\.(md|mdx)$/, "") === slug);

if (!caseData) {
  throw new Error(`Case not found for slug: ${slug}`);
}

const { Content } = await render(caseData);
const collected = caseData.data.pubDate.toISOString().split("T")[0];
const sorted = [...cases].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const specimenId = String(sorted.findIndex((entry) => entry.id === caseData.id) + 1).padStart(
  4,
  "0",
);
---

<Layout title={`${caseData.data.title} | MARKET`} description={caseData.data.title}>
  <article class="case-detail">
    <SpecimenLabel
      id={specimenId}
      titleCn={caseData.data.title}
      titleEn="Market specimen"
      collected={collected}
      location="digital sediment"
      composition="commerce / experiment"
      status={caseData.data.status === "Archived" ? "archived" : "crystallizing"}
      variant="full"
    />

    <div class="observation-section">
      <div class="observation-label">OBSERVATION</div>
      <p class="observation-text">{caseData.data.observation}</p>
    </div>

    <div class="case-content">
      <Content />
    </div>

    <ChoicePanel
      prompt="离开交易抽屉 / Close this drawer"
      options={[
        { label: "回到列表", href: "/market" },
        { label: "进入碎片柜", href: "/fragments" },
      ]}
    />

    <a href="/market" class="back-link">[ BACK TO MARKET ]</a>
  </article>
</Layout>

<style>
.case-detail {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.observation-section {
  margin-bottom: var(--space-8);
  padding: var(--space-6);
  border: var(--border-thin);
  background: var(--bg-shelf);
}

.observation-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rock-granite);
  margin-bottom: var(--space-3);
}

.observation-text {
  font-size: var(--text-base);
  color: var(--paper-bone);
  margin: 0;
  line-height: 1.75;
  font-style: italic;
}

.case-content {
  font-size: var(--text-base);
  line-height: 1.75;
  color: var(--paper-bone);
}

.case-content :global(p) {
  margin: 0 0 var(--space-4) 0;
}

.case-content :global(h2) {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  margin: var(--space-8) 0 var(--space-4) 0;
}

.back-link {
  display: inline-block;
  margin-top: var(--space-12);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--paper-bone);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.back-link:hover {
  opacity: 0.7;
}
</style>
