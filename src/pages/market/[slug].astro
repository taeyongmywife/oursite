---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from 'astro:content';
import { getEntryPath } from '../../lib/content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((c) => ({
    params: { slug: getEntryPath(c) },
  }));
}

const cases = await getCollection('cases');
const slug = Astro.params.slug;
const caseData = cases.find((entry) => getEntryPath(entry) === slug);

if (!caseData) {
  throw new Error(`Case not found for slug: ${slug}`);
}

const { Content } = await render(caseData);
---

<Layout title={`${caseData.data.title} | MARKET`} description={caseData.data.title}>
  <article class="case-detail">
    <div class="case-header">
      <span class="case-id">CASE_001</span>
      <span class="case-status">{caseData.data.status}</span>
    </div>
    
    <h1 class="case-title">{caseData.data.title}</h1>
    
    <div class="case-meta">
      <div class="meta-item">
        <span class="meta-label">DATE:</span>
        <span class="meta-value">{caseData.data.pubDate.toISOString().split('T')[0]}</span>
      </div>
    </div>

    <div class="observation-section">
      <h2 class="observation-label">OBSERVATION</h2>
      <p class="observation-text">{caseData.data.observation}</p>
    </div>

    <div class="case-content">
      <Content />
    </div>

    <a href="/market" class="back-link">[ BACK TO MARKET ]</a>
  </article>
</Layout>

<style>
.case-detail {
  padding: var(--space-16) 0;
  max-width: 680px;
  margin: 0 auto;
}

.case-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-8);
}

.case-id {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--muted);
}

.case-status {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--accent);
  border: 1px solid var(--accent-soft);
  padding: var(--space-1) var(--space-3);
}

.case-title {
  font-size: var(--text-3xl);
  font-weight: var(--font-normal);
  margin: 0 0 var(--space-8) 0;
  line-height: var(--leading-tight);
}

.case-meta {
  margin-bottom: var(--space-8);
}

.meta-item {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  display: flex;
  gap: var(--space-2);
}

.meta-label {
  color: var(--muted);
}

.meta-value {
  color: var(--foreground);
}

.observation-section {
  margin-bottom: var(--space-8);
  padding: var(--space-6);
  border: 1px solid var(--border);
  background-color: var(--background-elevated);
}

.observation-label {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin: 0 0 var(--space-3) 0;
}

.observation-text {
  font-size: var(--text-base);
  color: var(--foreground);
  margin: 0;
  line-height: var(--leading-relaxed);
  font-style: italic;
}

.case-content {
  font-size: var(--text-base);
  line-height: var(--leading-relaxed);
  color: var(--foreground);
}

.case-content :global(p) {
  margin: 0 0 var(--space-4) 0;
}

.case-content :global(h2) {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  margin: var(--space-8) 0 var(--space-4) 0;
}

.back-link {
  display: inline-block;
  margin-top: var(--space-12);
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  color: var(--foreground);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.back-link:hover {
  opacity: 0.7;
}
</style>
