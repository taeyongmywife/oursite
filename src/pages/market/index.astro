---
import Layout from "../../layouts/Layout.astro";

import SectionHeader from "../../components/SectionHeader.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import ProductCard from "../../components/cards/ProductCard.astro";
import { getCollection } from "astro:content";

const products = await getCollection("products");
const sortedProducts = [...products].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Count products by category
const toolsCount = products.filter(p => p.data.category === 'Tools').length;
const knowledgeCount = products.filter(p => p.data.category === 'Knowledge').length;
const worksCount = products.filter(p => p.data.category === 'Works').length;

const categories = [
  {
    id: '001',
    titleCn: '工具',
    titleEn: 'Tools',
    description: '精心选品的数字硬件与生产力工具',
    descriptionEn: 'Curated digital hardware & productivity tools',
    count: toolsCount,
    unit: '件',
    category: 'Tools',
    href: '/market/tools',
  },
  {
    id: '002',
    titleCn: '知识',
    titleEn: 'Knowledge',
    description: '深度思考和知识沉淀',
    descriptionEn: 'Deep thinking and knowledge crystallization',
    count: knowledgeCount,
    unit: '卷',
    category: 'Knowledge',
    href: '/market/knowledge',
  },
  {
    id: '003',
    titleCn: '作品',
    titleEn: 'Works',
    description: '创意作品和数字艺术品',
    descriptionEn: 'Creative projects and digital artifacts',
    count: worksCount,
    unit: '帧',
    category: 'Works',
    href: '/market/works',
  },
];

// Get featured products (latest 5, single row)
const featuredProducts = sortedProducts.slice(0, 5);
---

<Layout title="MARKET | BubbleCrisp" description="Market - 安静的策展商店">
  <section class="page">
    <SectionHeader en="MARKET" cn="策展商店" count={products.length} />
    
    <!-- Visual Center: Categories -->
    <div class="categories-section">
      <div class="categories-grid">
        {categories.map((cat) => (
          <CategoryCard {...cat} />
        ))}
      </div>
    </div>

    <!-- Minimalist Section: Recently Added -->
    <div class="recent-section">
      <div class="recent-header">
        <div class="recent-title">RECENTLY ADDED</div>
        <div class="recent-line"></div>
      </div>
      <div class="products-row">
        {featuredProducts.map((product, index) => (
          <div class="product-item">
            <ProductCard
              id={String(sortedProducts.length - index).padStart(3, '0')}
              href={`/market/${product.slug}`}
              titleCn={product.data.title}
              titleEn={product.data.subject}
              status={product.data.status}
              price={product.data.price}
              coverImage={product.data.coverImage}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
.page {
  padding: var(--space-16) 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-24);
}

/* Categories Section - Refined Size */
.categories-section {
  width: 100%;
  max-width: 900px; /* Limit max width to reduce size on large screens */
  margin: 0 auto;
}

.categories-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4); /* Reduced gap */
}

/* Recent Section - Subordinate & Horizontal */
.recent-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.recent-header {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.recent-title {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--rock-granite);
  white-space: nowrap;
}

.recent-line {
  flex: 1;
  height: 1px;
  background: var(--rock-basalt);
}

.products-row {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr)); /* Force equal width even with long text */
  gap: var(--space-4);
}

.product-item {
  width: 100%;
  display: flex; /* Ensure the item stretches vertically */
}

/* Override ProductCard styles for small size in row */
.product-item :global(.product-content) {
  padding: var(--space-3);
  grid-template-rows: 2.4em 3.3em 1fr 1.2em;
  row-gap: var(--space-2);
}

.product-item :global(.product-title) {
  font-size: var(--text-sm);
  line-height: 1.2;
}

.product-item :global(.product-subject) {
  font-size: var(--text-xs);
  line-height: 1.2;
}

.product-item :global(.product-price) {
  font-size: var(--text-base);
  line-height: 1;
}

@media (max-width: 1024px) {
  .categories-grid {
    gap: var(--space-4);
  }
}

@media (max-width: 768px) {
  .page {
    gap: var(--space-16);
  }

  .categories-grid {
    grid-template-columns: 1fr;
  }
  
  .products-row {
    gap: var(--space-2); /* Even tighter gap for mobile to fit 5 */
  }

  .product-item :global(.product-title) {
    font-size: var(--text-xs); /* Scale down font for mobile */
  }
}
</style>
