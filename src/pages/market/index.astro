---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import SectionHeader from "../../components/SectionHeader.astro";

const cases = await getCollection("cases");
const sorted = [...cases].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="MARKET | BubbleCrisp" description="Market Lab - A record of business experiments.">
  <section class="page">
    <SectionHeader en="MARKET" cn="商业实验" count={cases.length} />
    <p class="section-intro">
      This is the only drawer allowed to feel slightly transactional. Still: quiet, numbered,
      and filed.
    </p>

    <div class="list">
      {sorted.map((c, i) => (
        <a href={`/market/${c.id.replace(/\.(md|mdx)$/, "")}`} class="market-item">
          <div class="market-head">
            <div class="market-id">#{String(cases.length - i).padStart(4, "0")}</div>
            <div class="market-status">{c.data.status}</div>
          </div>
          <div class="market-title">{c.data.title}</div>
          <div class="market-desc">{c.data.observation}</div>
          <div class="market-meta">{c.data.pubDate.toISOString().split("T")[0]}</div>
        </a>
      ))}

      {cases.length === 0 && <div class="empty-state">No market experiments yet.</div>}
    </div>
  </section>
</Layout>

<style>
.page {
  padding: var(--space-16) 0;
}

.section-intro {
  margin: 0 0 var(--space-8) 0;
  color: var(--paper-rust);
}

.list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.market-item {
  display: block;
  padding: var(--space-6);
  border: var(--border-solid);
  background: rgba(10, 10, 12, 0.72);
  text-decoration: none;
  transition: opacity var(--duration-base) var(--ease-out);
}

.market-item:hover {
  opacity: 0.85;
}

.market-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: var(--space-4);
  margin-bottom: var(--space-2);
}

.market-id {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--mineral-copper);
  letter-spacing: 0.05em;
}

.market-status {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.market-title {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  color: var(--mineral-copper);
}

.market-desc {
  margin-top: var(--space-3);
  color: var(--paper-bone);
}

.market-meta {
  margin-top: var(--space-3);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
}

.empty-state {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  padding: var(--space-12) 0;
  text-align: center;
}
</style>
