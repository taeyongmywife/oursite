---
import Layout from "../layouts/Layout.astro";

const items = [
  {
    title: "蓝色工具包",
    desc: "一个用途尚未完全定义的数字工具集合",
    price: "¥29",
    slug: "blue-toolkit"
  },
  {
    title: "记忆碎片合集",
    desc: "一组可下载的视觉与文本素材",
    price: "¥19",
    slug: "memory-fragments"
  },
  {
    title: "实体物件 A",
    desc: "可触摸的未知用途物品（实验性）",
    price: "¥99",
    slug: "object-a"
  }
];
---

<Layout>

  <p style="opacity:0.5; letter-spacing:2px;">MARKET</p>

  <h1 style="font-size:36px;">Market</h1>

  <p style="opacity:0.6; margin-top:10px;">
    一些仍在流动中的物件
  </p>

  <div style="margin-top:60px; display:flex; flex-direction:column; gap:24px;">

    {items.map(item => (
      <a
        href={`/market/${item.slug}`}
        style="text-decoration:none; color:inherit;"
      >
        <div style="border-left:2px solid #eee; padding:14px 18px;">
          <h3 style="margin:0;">{item.title}</h3>
          <p style="opacity:0.6; margin:6px 0 0;">
            {item.desc}
          </p>
          <p style="margin:6px 0 0; font-size:14px;">
            {item.price}
          </p>
        </div>
      </a>
    ))}

  </div>

</Layout>