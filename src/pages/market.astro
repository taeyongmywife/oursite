---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/cards/ProductCard.astro';

const items = [
  {
    title: "蓝色工具包",
    description: "一个用途尚未完全定义的数字工具集合",
    price: "¥29",
    slug: "blue-toolkit"
  },
  {
    title: "记忆碎片合集",
    description: "一组可下载的视觉与文本素材",
    price: "¥19",
    slug: "memory-fragments"
  },
  {
    title: "实体物件 A",
    description: "可触摸的未知用途物品（实验性）",
    price: "¥99",
    slug: "object-a"
  }
];
---

<Layout>
  <p style="opacity: 0.6; letter-spacing: 2px;">MARKET</p>
  <h1 style="font-size: 36px; margin-top: 20px;">Market</h1>
  <p style="margin-top: 16px; line-height: 1.6; opacity: 0.8;">
    一些仍在流动中的物件
  </p>

  <div style="margin-top: 48px; display: flex; flex-direction: column; gap: 16px;">
    {items.map(item => (
      <ProductCard
        href={`/market/${item.slug}`}
        title={item.title}
        description={item.description}
        price={item.price}
      />
    ))}
  </div>
</Layout>