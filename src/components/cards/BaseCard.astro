---
interface Props {
  href?: string;
  size?: 'sm' | 'md';
  hover?: boolean;
  class?: string;
  [key: string]: unknown;
}

const { href, size = 'md', hover = true, class: className = '', ...rest } = Astro.props;
const cardClasses = [
  'card',
  size === 'sm' ? 'card-sm' : '',
  !hover ? 'card-no-hover' : '',
  className
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={cardClasses} {...rest}>
    <slot />
  </a>
) : (
  <div class={cardClasses} {...rest}>
    <slot />
  </div>
)}
