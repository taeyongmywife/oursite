---
import BaseCard from './BaseCard.astro';

interface Props {
  href: string;
  id: string;
  title: string;
  description: string;
  date: string;
  category: string;
  status: string;
  readingTime?: number;
  [key: string]: unknown;
}

const { href, id, title, description, date, category, status, readingTime, ...rest } = Astro.props;

// 状态颜色映射 - 适配新配色
const statusColors: Record<string, string> = {
  '持续观察中': '#7fa998',
  '研究中': '#5a7a9f',
  '已归档': '#737373',
  '进行中': '#b88f4a',
};

const statusColor = statusColors[status] || '#6b7280';
---

<BaseCard href={href} {...rest}>
  <div class="archive-card">
    <div class="archive-header">
      <span class="archive-id">{id}</span>
      <span class="archive-status" style={{ color: statusColor }}>{status}</span>
    </div>

    <h3 class="archive-title">{title}</h3>
    <p class="archive-description">{description}</p>

    <div class="archive-meta">
      <div class="meta-item">
        <span class="meta-label">Subject:</span>
        <span class="meta-value">{category}</span>
      </div>
      <div class="meta-row">
        <div class="meta-item">
          <span class="meta-label">Date:</span>
          <span class="meta-value mono">{date}</span>
        </div>
        {readingTime && (
          <div class="meta-item">
            <span class="meta-label">Time:</span>
            <span class="meta-value mono">{readingTime} min</span>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseCard>

<style>
.archive-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.archive-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.archive-id {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  color: var(--muted);
  letter-spacing: 0.05em;
}

.archive-status {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
  padding: var(--space-1) var(--space-3);
  border: 1px solid currentColor;
  border-radius: var(--radius-sm);
  opacity: 0.8;
}

.archive-title {
  font-size: var(--text-xl);
  font-weight: var(--font-semibold);
  line-height: var(--leading-tight);
  margin: 0;
  color: var(--foreground);
}

.archive-description {
  font-size: var(--text-sm);
  line-height: var(--leading-relaxed);
  margin: 0;
  color: var(--muted);
}

.archive-meta {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-top: var(--space-4);
  border-top: 1px solid var(--border);
}

.meta-row {
  display: flex;
  gap: var(--space-6);
}

.meta-item {
  display: flex;
  gap: var(--space-2);
}

.meta-label {
  font-size: var(--text-xs);
  font-family: var(--font-mono);
  color: var(--muted-soft);
  font-weight: var(--font-medium);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.meta-value {
  font-size: var(--text-sm);
  color: var(--muted);
}

.meta-value.mono {
  font-family: var(--font-mono);
}
</style>
