---
const nav = [
  { name: "Home", href: "/" },
  { name: "Blog", href: "/blog" },
  { name: "Projects", href: "/projects" },
  { name: "Market", href: "/market" },
  { name: "About", href: "/about" }
];
---

<header class="nav">
  <div class="logo">
    <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128">
      <circle cx="64" cy="64" r="58" fill="none" stroke="currentColor" stroke-width="8"/>
      <path d="M64 18 L72 56 L110 64 L72 72 L64 110 L56 72 L18 64 L56 56 Z" fill="currentColor"/>
      <path d="M64 36 L68 56 L88 64 L68 72 L64 92 L60 72 L40 64 L60 56 Z" fill="none" stroke="var(--background)" stroke-width="4"/>
    </svg>
    BubbleCrisp
  </div>

  <nav>
    {nav.map(i => (
      <a href={i.href}>{i.name}</a>
    ))}
  </nav>
</header>

<style>
.nav {
  display: flex;
  justify-content: space-between;
  padding: var(--space-4) var(--space-6);
  border-bottom: 1px solid var(--border);
  background-color: var(--background-elevated);
}

nav {
  display: flex;
  gap: var(--space-5);
}

a {
  text-decoration: none;
  color: var(--foreground);
  font-size: var(--text-sm);
  transition: color var(--duration-base) var(--ease-out);
}

a:hover {
  color: var(--accent);
}

.logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-weight: var(--font-semibold);
  font-size: var(--text-sm);
  letter-spacing: 0.05em;
}

.logo-icon {
  width: 24px;
  height: 24px;
  color: var(--foreground);
}
</style>