---
const nav = [
  { name: "FRAGMENTS", nameCN: "碎片档案", href: "/fragments" },
  { name: "EXPERIMENTS", nameCN: "实验记录", href: "/experiments" },
  { name: "MARKET", nameCN: "商业实验", href: "/market" },
  { name: "IDENTITY", nameCN: "个人档案", href: "/identity" }
];
---

<header class="nav">
  <a href="/" class="logo">
    <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128">
      <circle cx="64" cy="64" r="58" fill="none" stroke="currentColor" stroke-width="8"/>
      <path d="M64 18 L72 56 L110 64 L72 72 L64 110 L56 72 L18 64 L56 56 Z" fill="currentColor"/>
      <path d="M64 36 L68 56 L88 64 L68 72 L64 92 L60 72 L40 64 L60 56 Z" fill="none" stroke="var(--background)" stroke-width="4"/>
    </svg>
    BubbleCrisp
  </a>

  <nav>
    {nav.map(i => (
      <a href={i.href} class="nav-link">
        <span class="nav-link-en">{i.name}</span>
        <span class="nav-link-cn">{i.nameCN}</span>
      </a>
    ))}
  </nav>
</header>

<style>
.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-4) var(--space-6);
  border-bottom: 1px solid var(--border);
  background-color: var(--background-elevated);
  position: sticky;
  top: 0;
  z-index: 100;
}

nav {
  display: flex;
  gap: var(--space-8);
}

.nav-link {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  transition: opacity var(--duration-base) var(--ease-out);
}

.nav-link:hover {
  opacity: 0.7;
}

.nav-link-en {
  color: var(--foreground);
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.nav-link-cn {
  color: var(--muted);
  font-size: var(--text-xs);
}

.logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-weight: var(--font-semibold);
  font-size: var(--text-sm);
  letter-spacing: 0.05em;
  color: var(--foreground);
  text-decoration: none;
}

.logo-icon {
  width: 24px;
  height: 24px;
  color: var(--foreground);
}
</style>