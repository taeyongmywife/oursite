---
interface Props {
  id: string;
  titleCn: string;
  titleEn: string;
  collected?: string;
  location?: string;
  composition?: string;
  status?: "forming" | "crystallizing" | "archived" | "dissolved";
  variant?: "full" | "compact";
}

const {
  id,
  titleCn,
  titleEn,
  collected,
  location,
  composition,
  status,
  variant = "full",
} = Astro.props;

const normalizedId = id.padStart(4, "0");
---

<section class:list={["specimen-label", `variant-${variant}`]}>
  <div class="specimen-head">[SPECIMEN #{normalizedId}]</div>
  <div class="specimen-titles">
    <div class="specimen-title-cn">CN: {titleCn}</div>
    <div class="specimen-title-en">EN: {titleEn}</div>
  </div>

  <div class="specimen-sep"></div>

  {variant === "full" ? (
    <div class="specimen-meta">
      {collected && (
        <div class="meta-row">
          <span class="meta-key">COLLECTED:</span>
          <span class="meta-val">{collected}</span>
        </div>
      )}
      {location && (
        <div class="meta-row">
          <span class="meta-key">LOCATION:</span>
          <span class="meta-val">{location}</span>
        </div>
      )}
      {composition && (
        <div class="meta-row">
          <span class="meta-key">COMPOSITION:</span>
          <span class="meta-val">{composition}</span>
        </div>
      )}
      {status && (
        <div class="meta-row">
          <span class="meta-key">STATUS:</span>
          <span class="meta-val">{status}</span>
        </div>
      )}
    </div>
  ) : (
    <div class="specimen-compact-meta">
      {(collected || status) && (
        <span>
          {collected ?? "—"} · {status ?? "—"}
        </span>
      )}
    </div>
  )}
</section>

<style>
.specimen-label {
  border: var(--border-thin);
  padding: var(--space-4);
  font-family: var(--font-mono);
}

.specimen-head {
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.05em;
  color: var(--mineral-copper);
}

.specimen-titles {
  margin-top: var(--space-2);
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.specimen-title-cn {
  font-family: var(--font-serif);
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--paper-bone);
}

.specimen-title-en {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.05em;
  color: var(--paper-rust);
}

.specimen-sep {
  height: 1px;
  background: var(--rock-basalt);
  margin: var(--space-3) 0;
}

.specimen-meta {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.meta-row {
  display: flex;
  gap: var(--space-2);
  font-size: var(--text-xs);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rock-granite);
}

.meta-val {
  letter-spacing: 0;
  text-transform: none;
  color: var(--paper-bone);
}

.specimen-compact-meta {
  font-size: var(--text-xs);
  color: var(--rock-granite);
  letter-spacing: 0.05em;
}
</style>
