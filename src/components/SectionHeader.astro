---
interface Props {
  en: string;
  cn: string;
  count?: number;
}

const { en, cn, count } = Astro.props;
const countText = count !== undefined ? count.toString().padStart(4, "0") : undefined;
---

<header class="section-header">
  <div class="section-header-en">
    {en}
    {countText && <span class="count"> · {countText}</span>}
  </div>
  <h2 class="section-header-cn">{cn}</h2>
  <div class="section-header-line"></div>
</header>

<style>
.section-header {
  margin-bottom: var(--space-8);
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.section-header-en {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  letter-spacing: 0.15em;
  color: var(--paper-bone);
  text-transform: uppercase;
}

.section-header-en .count {
  color: var(--mineral-copper);
}

.section-header-cn {
  font-family: var(--font-serif);
  font-size: var(--text-2xl);
  font-weight: 400;
  color: var(--paper-bone);
  margin: 0;
}

.section-header-line {
  height: 1px;
  background: var(--rock-granite);
  margin-top: var(--space-3);
}
</style>
