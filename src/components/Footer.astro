---
import { getCollection } from "astro:content";

const fragments = await getCollection("fragments");
const lastArchived = fragments
  .map((f) => f.data.pubDate)
  .sort((a, b) => b.getTime() - a.getTime())[0];

const currentId = String(fragments.length).padStart(4, "0");
---

<footer class="site-footer">
  <div class="footer-line">◆ BUBBLECRISP · CABINET OF CURIOSITIES</div>
  <div class="footer-meta">
    <span>持续运行于 2026 —</span>
    <span>最后归档：{lastArchived ? lastArchived.toISOString().split("T")[0] : "—"}</span>
    <span>当前标本：#{currentId}</span>
    <span>采集地：digital sediment</span>
  </div>
  <div class="footer-motto">"I crystallize, therefore I am."</div>
</footer>
<style>
.site-footer {
  padding: var(--space-16) var(--container-pad) var(--space-24) var(--container-pad);
  border-top: var(--border-solid);
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  line-height: 1.8;
}

.footer-line {
  margin-bottom: var(--space-4);
}

.footer-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2) var(--space-6);
  margin-bottom: var(--space-4);
}

.footer-motto {
  color: var(--paper-rust);
}
</style>
