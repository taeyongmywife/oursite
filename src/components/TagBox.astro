---
interface TagInfo {
  id: number;
  title: string;
  slug: string;
}

interface PostInfo {
  title: string;
  slug: string;
  createdAt?: string;
}

interface Props {
  tag: TagInfo;
  posts: PostInfo[];
  basePath?: string;
}

const { tag, posts, basePath = "/fragments" } = Astro.props;
---

<section class="tag-box">
  <div class="tag-box-head">
    <div class="tag-box-name">{tag.title}</div>
    <div class="tag-box-count">{posts.length} 件</div>
  </div>
  <div class="tag-box-list">
    {posts.map((post, i) => (
      <a href={`${basePath}/${post.slug}`} class="tag-post-item">
        <div class="tag-post-left">
          <span class="tag-post-index">#{(i + 1).toString().padStart(3, "0")}</span>
          <span class="tag-post-title">{post.title}</span>
        </div>
        {post.createdAt && (
          <span class="tag-post-date">{post.createdAt.split("T")[0].replace(/-/g, ".")}</span>
        )}
      </a>
    ))}
  </div>
</section>

<style>
.tag-box {
  border: var(--border-solid);
  background: rgba(10, 10, 12, 0.72);
  transition: border-color var(--duration-base) var(--ease-out);
}

.tag-box:hover {
  border-color: var(--mineral-copper);
}

.tag-box-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: var(--space-5) var(--space-6);
  border-bottom: 1px solid var(--rock-basalt);
}

.tag-box-name {
  font-family: var(--font-mono);
  font-size: var(--text-sm);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--mineral-copper);
}

.tag-box-count {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
}

.tag-box-list {
  display: flex;
  flex-direction: column;
}

.tag-post-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-3) var(--space-6);
  text-decoration: none;
  transition: background var(--duration-base) var(--ease-out);
}

.tag-post-item:hover {
  background: rgba(255, 255, 255, 0.03);
}

.tag-post-item + .tag-post-item {
  border-top: 1px solid var(--rock-basalt);
}

.tag-post-left {
  display: flex;
  align-items: baseline;
  gap: var(--space-3);
  min-width: 0;
}

.tag-post-index {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  flex-shrink: 0;
}

.tag-post-title {
  font-family: var(--font-serif);
  font-size: var(--text-base);
  color: var(--paper-bone);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-post-date {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--rock-granite);
  flex-shrink: 0;
}
</style>
